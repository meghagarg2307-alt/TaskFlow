# =============================================================================
# Copy this file to .env (same directory) and fill in real values.
# `docker compose` automatically loads it.
#
#   cp infra/.env.example infra/.env
#   $EDITOR infra/.env
# =============================================================================

# ---- Required ---------------------------------------------------------------

# Postgres password — choose a long random string.
DB_PASSWORD=password123

# JWT signing secret — MUST be at least 32 bytes for HS256.
#   openssl rand -base64 48
JWT_SECRET=thisIsAStrongJwtSecretKeyAtLeast32CharactersLong

# ---- Optional ---------------------------------------------------------------

# Database name + user (alongside DB_PASSWORD above).
DB_NAME=taskflow
DB_USER=taskflow
DB_POOL_SIZE=20

# Redis password (leave blank for unauthenticated local-only redis).
REDIS_PASSWORD=

# Public-facing base URL of the deployment. Used as the CORS allow-list and
# WebSocket origin allow-list. Set to your real domain in production, e.g.
#   PUBLIC_URL=https://taskflow.example.com
PUBLIC_URL=http://localhost

# Cookie hardening. In production (HTTPS), set:
#   COOKIE_SECURE=true
#   COOKIE_SAMESITE=Strict
# For local plain-HTTP testing keep Secure=false (browsers reject Secure on
# non-HTTPS origins, blocking the refresh-token cookie entirely).
COOKIE_SECURE=false
COOKIE_SAMESITE=Strict

# Host port the nginx `web` container is mapped to.
HTTP_PORT=80
